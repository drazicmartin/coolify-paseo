FROM node:20-alpine

# system deps
RUN apk add --no-cache git bash curl

# create user
RUN adduser -D devuser

# install opencode globally
RUN npm install -g opencode-ai

# switch to user
USER devuser
WORKDIR /home/devuser/workspace

# FIX: required directories for opencode
RUN mkdir -p /home/devuser/.local/share/opencode/bin \
    && mkdir -p /home/devuser/.cache/opencode

EXPOSE 4096

CMD ["opencode", "web", "--port", "4096", "--hostname", "0.0.0.0"]